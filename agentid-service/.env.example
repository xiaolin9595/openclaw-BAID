NODE_ENV=development
ALLOW_DEVELOPMENT_AUTH=false
PORT=8787
HOST=0.0.0.0
DATABASE_URL=postgres://agentid:agentid@127.0.0.1:5432/agentid
ISSUER_URL=http://127.0.0.1:8787
# Use localhost for browser WebAuthn. Chromium rejects an IP address as a local RP ID.
WEB_ORIGIN=http://localhost:4173
ALLOWED_WEB_ORIGINS=http://localhost:4173
RP_ID=localhost
PASSKEY_STEP_UP_TTL_SECONDS=300
SERVICE_VERSION=0.1.0
METRICS_ALLOWED_IPS=127.0.0.1,::1
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_AUTH_WINDOW_SECONDS=600
RATE_LIMIT_AGENT_CHANGES_MAX=60
RATE_LIMIT_AGENT_CHANGES_WINDOW_SECONDS=60
RATE_LIMIT_APPROVALS_MAX=60
RATE_LIMIT_APPROVALS_WINDOW_SECONDS=60
RATE_LIMIT_BINDING_STATUS_MAX=300
RATE_LIMIT_BINDING_STATUS_WINDOW_SECONDS=60
RATE_LIMIT_BINDING_RENEWAL_MAX=60
RATE_LIMIT_BINDING_RENEWAL_WINDOW_SECONDS=60
RATE_LIMIT_OAUTH_DEVICE_MAX=30
RATE_LIMIT_OAUTH_DEVICE_WINDOW_SECONDS=60
RATE_LIMIT_OAUTH_TOKEN_MAX=120
RATE_LIMIT_OAUTH_TOKEN_WINDOW_SECONDS=60
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
ISSUER_PRIVATE_KEY_PATH=./secrets/issuer-ed25519.pem
# Stable secret used to derive the non-reversible user_id_hash claim in IBCs.
USER_ID_HASH_SECRET=replace-with-a-random-32-byte-secret
EMAIL_PROVIDER=console
# Set EMAIL_PROVIDER=resend for real email delivery.
RESEND_API_KEY=
RESEND_FROM_EMAIL=AgentID <no-reply@example.com>
MAGIC_LINK_WEBHOOK_URL=
