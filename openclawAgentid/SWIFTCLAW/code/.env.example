# Moonshot (Kimi) API 配置
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Tavily Search API 配置
TAVILY_API_KEY=your_tavily_api_key_here

# Telegram Bot 配置
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 可选：白名单用户 Telegram ID（逗号分隔）
TELEGRAM_ALLOWED_USERS=123456789,987654321

# 服务器配置
PORT=8000
LOG_LEVEL=INFO

# 浏览器自动化配置
# false = 打开可见窗口，true = 无头模式
BROWSER_HEADLESS=false
# 默认优先使用 Edge；如果想改成 Playwright 默认 Chromium，可留空
BROWSER_CHANNEL=msedge
# 可选：显式指定浏览器可执行文件路径
# BROWSER_EXECUTABLE_PATH=/path/to/msedge

# 可选：本地浏览器代理公网地址
# 配合你电脑上运行的 local_browser.py + ngrok 使用
# LOCAL_BROWSER_PROXY=https://xxxx.ngrok-free.app

# 如果 Telegram Bot 也运行在同一台 Windows 电脑上，可以直接用本机地址，
# 这样不需要 ngrok:
# LOCAL_BROWSER_PROXY=http://127.0.0.1:8789

# 文件操作根目录
# 建议设置成你本机真正会打开的目录，比如桌面、文档或同步盘
# Windows 示例：D:\\swiftclaw
# FILE_WORK_DIR=/home/yourname/Documents/swiftclaw
