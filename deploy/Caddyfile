{
  email admin@agentid-baid.site
}

agentid-baid.site {
  tls /certs/live/agentid-baid.site/fullchain.pem /certs/live/agentid-baid.site/privkey.pem
  encode gzip

  @api path /v1/* /oauth/* /.well-known/* /health* /metrics*
  handle @api {
    reverse_proxy agentid-service:8787
  }

  handle /device* {
    rewrite * /device.html
    file_server
  }

  handle {
    root * /srv
    try_files {path} {path}/ /index.html
    file_server
  }
}
